{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Meta",
  "type": "object",
  "required": ["experiment_id", "date", "model", "workload_profile"],
  "properties": {
    "experiment_id": {"type": "string"},
    "date": {"type": "string"},
    "owner": {"type": "string"},
    "issue_id": {"type": "string"},
    "branch": {"type": "string"},
    "commit_hash": {"type": "string"},
    "tag": {"type": "string"},
    "status": {"type": "string"},
    "optimization_target": {"type": "string"},
    "optimization_module": {"type": "string"},
    "change_summary": {"type": "string"},
    "hypothesis": {"type": "string"},
    "model": {"type": "string"},
    "spec_method": {"type": "string"},
    "num_speculative_tokens": {"type": "number"},
    "policy_name": {"type": "string"},
    "workload_profile": {"type": "string"},
    "hardware_profile": {"type": "string"},
    "gpu_type": {"type": "string"},
    "gpu_count": {"type": "number"},
    "memory_budget": {"type": "string"},
    "cuda_version": {"type": "string"},
    "vllm_version": {"type": "string"},
    "speculators_version": {"type": "string"},
    "seed": {"type": "number"}
  },
  "additionalProperties": true
}
