{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Summary",
  "type": "object",
  "required": [
    "experiment_id",
    "metrics",
    "stability",
    "result_label"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "metrics": {
      "type": "object",
      "properties": {
        "ttft_p50_ms": {"type": "number"},
        "ttft_p95_ms": {"type": "number"},
        "tpot_p50_ms": {"type": "number"},
        "tpot_p95_ms": {"type": "number"},
        "itl_mean_ms": {"type": "number"},
        "throughput_tok_per_s": {"type": "number"},
        "goodput": {"type": "number"},
        "acceptance_rate_mean": {"type": "number"},
        "accepted_tokens": {"type": "number"},
        "proposed_tokens": {"type": "number"},
        "rejected_tokens": {"type": "number"},
        "expert_cache_hit_rate": {"type": "number"},
        "wasted_prefetched_bytes": {"type": "number"},
        "gpu_mem_peak_mb": {"type": "number"},
        "kv_cache_peak_mb": {"type": "number"},
        "speculative_budget_mb": {"type": "number"},
        "expert_budget_mb": {"type": "number"}
      },
      "additionalProperties": true
    },
    "stability": {
      "type": "object",
      "properties": {
        "oom_count": {"type": "integer", "minimum": 0},
        "fallback_count": {"type": "integer", "minimum": 0},
        "run_success_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "result_label": {
      "type": "string",
      "enum": ["win", "partial_win", "neutral", "regression", "invalid"]
    },
    "primary_gain": {"type": "string"},
    "primary_cost": {"type": "string"},
    "final_conclusion": {"type": "string"}
  },
  "additionalProperties": true
}
